# Local development: skip Firebase entirely and run as a fixed dev user.
# Pair with AUTH_DISABLED=true on the backend (see api/.env). To test real auth
# locally, set this to false and fill in the VITE_FIREBASE_* values below.
VITE_AUTH_DISABLED=true

# Public Firebase web config (only used when VITE_AUTH_DISABLED=false).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
